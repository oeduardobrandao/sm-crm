# ─────────────────────────────────────────────────────────────────────────────
# Switching between PROD and STAGING (local dev)
# ─────────────────────────────────────────────────────────────────────────────
# Vite's envDir is the repo root, and `--mode staging` overlays `.env.staging`
# on top of `.env`. So:
#   • .env          → PROD   (default — used by `npm run dev`, `dev:hub`, `dev:admin`)
#   • .env.staging  → STAGING overrides (only VITE_SUPABASE_URL/ANON_KEY differ)
#
# Run any app against staging with the `:staging` script variant:
#   npm run dev:staging         # CRM   → staging  (:5173)
#   npm run dev:hub:staging     # Hub   → staging  (:5175)
#   npm run dev:admin:staging   # Admin → staging  (:5177)
# Or all three at once (one terminal, Ctrl+C stops all):
#   npm run dev:all             # CRM + Hub + Admin → prod
#   npm run dev:all:staging     # CRM + Hub + Admin → staging
# Backend (CLI) switching is separate:
#   npm run db:link:staging  /  db:link:prod
#   npm run functions:deploy:staging  /  functions:deploy:prod
# Project refs: prod=skjzpekeqefvlojenfsw  staging=wlyzhyfondykzpsiqsce
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Configuration
# Get these from: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry (optional — omit to disable error tracking)
VITE_SENTRY_DSN=

# Seed/unseed scripts (scripts/seed-demo.mjs, scripts/unseed-demo.mjs)
SEED_EMAIL=your-test-email@example.com
SEED_PASSWORD=your-test-password

# Edge function secrets — set via `npx supabase secrets set`, NOT loaded from this file.
# Listed here for documentation. Never commit real values.
# Stripe billing (billing-checkout / billing-portal / stripe-webhook)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
