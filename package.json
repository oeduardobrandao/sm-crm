{
  "name": "sm-crm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --config apps/crm/vite.config.ts",
    "dev:hub": "vite --config apps/hub/vite.config.ts",
    "dev:staging": "vite --config apps/crm/vite.config.ts --mode staging",
    "build": "tsc -p apps/crm/tsconfig.json && vite build --config apps/crm/vite.config.ts",
    "build:hub": "tsc -p apps/hub/tsconfig.json && vite build --config apps/hub/vite.config.ts",
    "build:staging": "tsc -p apps/crm/tsconfig.json && vite build --config apps/crm/vite.config.ts --mode staging",
    "preview": "vite preview --config apps/crm/vite.config.ts",
    "lint": "eslint apps/ packages/",
    "lint:fix": "eslint apps/ packages/ --fix",
    "format": "prettier --write 'apps/**/*.{ts,tsx}' 'packages/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'apps/**/*.{ts,tsx}' 'packages/**/*.{ts,tsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:crm": "playwright test --project=crm",
    "test:e2e:hub": "playwright test --project=hub",
    "dev:admin": "vite --config apps/admin/vite.config.ts --port 5177",
    "build:admin": "tsc -p apps/admin/tsconfig.json && vite build --config apps/admin/vite.config.ts",
    "db:link:staging": "npx supabase link --project-ref wlyzhyfondykzpsiqsce",
    "db:link:prod": "npx supabase link --project-ref skjzpekeqefvlojenfsw",
    "db:push": "npx supabase db push --linked",
    "functions:deploy:staging": "npx supabase functions deploy --project-ref wlyzhyfondykzpsiqsce",
    "functions:deploy:prod": "npx supabase functions deploy --project-ref skjzpekeqefvlojenfsw",
    "seed": "node scripts/seed-demo.mjs",
    "seed:staging": "node scripts/seed-demo.mjs --staging",
    "unseed": "node scripts/unseed-demo.mjs",
    "unseed:staging": "node scripts/unseed-demo.mjs --staging"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "^10.55.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.14",
    "@tiptap/extension-color": "^3.24.0",
    "@tiptap/extension-highlight": "^3.24.0",
    "@tiptap/extension-link": "^3.24.0",
    "@tiptap/extension-placeholder": "^3.24.0",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-underline": "^3.24.0",
    "@tiptap/extension-youtube": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "@types/diff-match-patch": "^1.0.36",
    "@vercel/analytics": "^2.0.1",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.21",
    "diff-match-patch": "^1.0.5",
    "i18next": "^26.3.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-day-picker": "^9.7.0",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "shadcn": "^4.10.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.60.1",
    "vite": "6.4.2",
    "vitest": "^3.2.4"
  }
}
